<Window x:Class="WhackerLinkConsoleV2.DispatcherRidSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dispatcher RID Settings" Height="250" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dispatcher Radio ID (RID) Configuration" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

        <CheckBox x:Name="EnableOverrideCheckBox" Content="Override RID from codeplug" Grid.Row="1" Margin="0,0,0,15"
                  Checked="EnableOverrideCheckBox_CheckedChanged" Unchecked="EnableOverrideCheckBox_CheckedChanged"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,15" IsEnabled="{Binding ElementName=EnableOverrideCheckBox, Path=IsChecked}">
            <TextBlock Text="Dispatcher RID:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="RidTextBox" Width="200" HorizontalAlignment="Left" MaxLength="10"/>
            <TextBlock Text="Enter your dispatcher radio ID (numeric)" FontStyle="Italic" Foreground="Gray" Margin="0,5,0,0" FontSize="11"/>
        </StackPanel>

        <TextBlock Grid.Row="3" TextWrapping="Wrap" Margin="0,0,0,10">
            <Run Text="When enabled, this RID will be used for all transmissions instead of the RID from the codeplug. " />
            <Run Text="This allows multiple dispatchers to use unique IDs on the same system." FontWeight="Bold"/>
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="5" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="100" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="100" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
