<Window x:Class="WhackerLinkConsoleV2.PttHotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PTT Hotkey Settings" Height="300" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Global PTT Hotkey Configuration" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

        <CheckBox x:Name="EnableHotkeyCheckBox" Content="Enable Global PTT Hotkey" Grid.Row="1" Margin="0,0,0,15"
                  Checked="EnableHotkeyCheckBox_CheckedChanged" Unchecked="EnableHotkeyCheckBox_CheckedChanged"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,15" IsEnabled="{Binding ElementName=EnableHotkeyCheckBox, Path=IsChecked}">
            <TextBlock Text="Modifier Keys:" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CtrlCheckBox" Content="Ctrl" Margin="0,0,15,0"/>
                <CheckBox x:Name="AltCheckBox" Content="Alt" Margin="0,0,15,0"/>
                <CheckBox x:Name="ShiftCheckBox" Content="Shift" Margin="0,0,15,0"/>
                <CheckBox x:Name="WinCheckBox" Content="Win" Margin="0,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15" IsEnabled="{Binding ElementName=EnableHotkeyCheckBox, Path=IsChecked}">
            <TextBlock Text="Key:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="HotkeyTextBox" Width="150" HorizontalAlignment="Left" IsReadOnly="True"
                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" Text="(Press a key)"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Example: Ctrl + Alt + F1" FontStyle="Italic" Foreground="Gray" VerticalAlignment="Top"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="5" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="100" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="100" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
